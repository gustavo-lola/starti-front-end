{
    "printWidth": 120,

    "tabWidth": 4,

    "useTabs": false,

    "semi": true,

    "singleQuote": false,

    "trailingComma": "es5",

    "bracketSpacing": true,

    "arrowParens": "always",

    "plugins": ["prettier-plugin-tailwindcss", "@ianvs/prettier-plugin-sort-imports"],

    "importOrder": [
        "^react$",
        "^react/(.*)$",
        "<THIRD_PARTY_MODULES>",
        "",
        "^@core/(.*)$",
        "^@server/(.*)$",
        "^@ui/(.*)$",
        "",
        "^[./]"
    ],

    "importOrderCaseSensitive": true
}
